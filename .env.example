# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, used by the weekly digest

# Amazon Bedrock (AWS Console -> Bedrock -> API keys)
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Ticketmaster Discovery API (developer.ticketmaster.com, free tier)
TICKETMASTER_API_KEY=your-tm-consumer-key

# Resend (resend.com) — weekly digest emails
RESEND_API_KEY=re_...
DIGEST_FROM_EMAIL=Concierge <digest@yourdomain.com>

# Shared secret protecting /api/digest (Vercel Cron sends it automatically
# when an env var named CRON_SECRET exists)
CRON_SECRET=generate-a-long-random-string

# Public URL of the deployed app (used in magic-link redirects + emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
